# ─────────────────────────────────────────────────────────────────────────────
#  SUVAIALAYA EVENT MANAGEMENT SYSTEM — Environment Variables
#  Copy this file to `.env` and fill in your real values.
#  Command: cp .env.example .env
#
#  ⚠️  NEVER commit .env to version control.
#  ⚠️  Use GitHub Actions Secrets / Docker Secrets in production.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
PORT=8080
NODE_ENV=development
LOG_LEVEL=info

# ── Database (MongoDB) ────────────────────────────────────────────────────────
# For LOCAL development (running pnpm dev):
MONGODB_URI=mongodb://127.0.0.1:27017/suvaialaya

# For Docker deployment with Replica Set (required for transactions):
# MONGODB_URI=mongodb://sems-db:27017/suvaialaya?replicaSet=rs0

# ── Redis (Seat Locking + BullMQ Queues) ─────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# REDIS_PASSWORD=your_redis_password_here  # Uncomment for production

# ── Authentication ────────────────────────────────────────────────────────────
# REQUIRED: Generate with: openssl rand -hex 64
JWT_SECRET=change_this_to_a_64_char_random_string_in_production

# ── Payment Gateway (Razorpay) ────────────────────────────────────────────────
# Get your keys from: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_your_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_secret_here

# Webhook secret from: https://dashboard.razorpay.com/app/webhooks
# REQUIRED for production webhook signature verification
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret_here

# ── Email Service (Resend) ────────────────────────────────────────────────────
# Get your API key from: https://resend.com/api-keys
RESEND_API_KEY=re_your_resend_api_key_here

# ── Security ──────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins for CORS
ALLOWED_ORIGINS=http://localhost:8080,https://suvaialaya.com,https://www.suvaialaya.com

# ── Alerting ──────────────────────────────────────────────────────────────────
# Email that receives all SRE alerts (payment failures, DLQ, memory, backups)
ALERT_EMAIL=owner@suvaialaya.com
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# ── Grafana / Monitoring ──────────────────────────────────────────────────────
GRAFANA_ADMIN_PASSWORD=change_me_in_production
DOMAIN=suvaialaya.com

# ── SMTP (for Grafana alert emails) ──────────────────────────────────────────
# SMTP_HOST=smtp.gmail.com:587
# SMTP_USER=your_email@gmail.com
# SMTP_PASSWORD=your_app_password
