# ─────────────────────────────────────────────────────────────────────────────
#  SUVAIALAYA EVENT MANAGEMENT SYSTEM — Environment Variables
#  Copy this file to `.env` and fill in your real values.
#  Command: cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ─────────────────────────────────────────────────────────────────
# For LOCAL development (running pnpm dev):
MONGODB_URI=mongodb://127.0.0.1:27017/suvaialaya

# For Docker deployment, this is automatically overridden by docker-compose.yml
# MONGODB_URI=mongodb://sems-db:27017/suvaialaya

# ── Authentication ────────────────────────────────────────────────────────────
# REQUIRED: Change this to a long, random string in production
JWT_SECRET=suvaialaya_super_secret_jwt_key_change_me_in_production

# ── Payment Gateway (Razorpay) ────────────────────────────────────────────────
# Get your keys from: https://dashboard.razorpay.com/app/keys
# Use TEST keys during development (prefix: rzp_test_)
RAZORPAY_KEY_ID=rzp_test_your_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_secret_here

# ── Email Service (Resend) ────────────────────────────────────────────────────
# Get your API key from: https://resend.com/api-keys
RESEND_API_KEY=re_your_resend_api_key_here

# ── Application ──────────────────────────────────────────────────────────────
PORT=8080
NODE_ENV=development
